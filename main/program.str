output=led name=myLed pin=16
write=myLed ON
read=myLed
write=myLed OFF

input=button name=myBut pin=18
read=myBut


# Inicializar sensor
I2C WRITE 0x76 0xF4 0x27

# Leer temperatura cruda
I2C READ 0x76 0xFA 3 -> T_RAW

# Convertir a grados (simplificado)
TEMP = (T_RAW / 5120)
PRINT TEMP
